# KodNestCareers local environment

NODE_ENV=development

# Postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=kodnest
POSTGRES_PASSWORD=kodnest
POSTGRES_DB=kodnest_careers

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Mailpit
MAILPIT_HOST=localhost
MAILPIT_SMTP_PORT=1025
MAILPIT_HTTP_PORT=8025

# Web app
WEB_PORT=3000

# Worker
WORKER_CONCURRENCY=5

# AI gateway
AI_GATEWAY_PROVIDER=openrouter

